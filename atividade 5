n1 = float(input("Primeira nota: "))
n2 = float(input("Segunda nota: "))

media = (n1 + n2) / 2

if media >= 9:
    conceito = "A"
elif media >= 7.5:
    conceito = "B"
elif media >= 6:
    conceito = "C"
elif media >= 4:
    conceito = "D"
else:
    conceito = "E"

if conceito in ["A", "B", "C"]:
    status = "APROVADO"
else:
    status = "REPROVADO"

print("Notas:", n1, "e", n2)
print("Média:", media)
print("Conceito:", conceito)
print(status)
