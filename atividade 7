morango = float(input("Kg de morango: "))
maca = float(input("Kg de maçã: "))

# preços
if morango <= 5:
    preco_morango = 2.50
else:
    preco_morango = 2.20

if maca <= 5:
    preco_maca = 1.80
else:
    preco_maca = 1.50

# cálculo total
total = (morango * preco_morango) + (maca * preco_maca)
kg_total = morango + maca

# desconto
if kg_total > 8 or total > 25:
    desconto = total * 0.10
else:
    desconto = 0

valor_final = total - desconto

print("Total: R$", total)
print("Desconto: R$", desconto)
print("Valor a pagar: R$", valor_final)
