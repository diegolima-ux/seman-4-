f1 = float(input("Primeira força: "))
f2 = float(input("Segunda força: "))
f3 = float(input("Terceira força: "))

if f1 + f2 > f3 and f1 + f3 > f2 and f2 + f3 > f1:
    print("As forças podem manter o equilíbrio.")

    if f1 == f2 == f3:
        print("Equilíbrio simétrico")
    elif f1 == f2 or f1 == f3 or f2 == f3:
        print("Equilíbrio parcialmente simétrico")
    else:
        print("Equilíbrio assimétrico")
else:
    print("As forças não podem manter o equilíbrio.")
